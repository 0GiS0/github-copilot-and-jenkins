pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 15, unit: 'MINUTES')
    }

    stages {
        stage('📥 Checkout') {
            steps {
                checkout scm
            }
        }

        stage('📦 Install') {
            steps {
                sh 'npm ci'
            }
        }

        stage('🧪 Test') {
            steps {
                sh 'npm test -- --runInBand'
            }
        }

        stage('🏗️ Build') {
            steps {
                sh 'npm run build'
            }
        }
    }
}