pipeline {
    agent any

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds(abortPrevious: true)
    }

    environment {
        GH_TOKEN = credentials('gh-token')
        COPILOT_GITHUB_TOKEN = credentials('gh-token')
        PATH = "${env.HOME}/.local/bin:/usr/local/bin:${env.PATH}"
    }

    parameters {
        choice(
            name: 'DOC_TYPE',
            choices: ['README', 'API', 'ALL'],
            description: 'Type of documentation to generate'
        )
        string(
            name: 'PR_NUMBER',
            defaultValue: '',
            description: 'Optional GitHub PR number. Uses CHANGE_ID automatically in multibranch PR builds.'
        )
        booleanParam(
            name: 'WRITE_BACK_TO_PR',
            defaultValue: true,
            description: 'Commit generated documentation back to the existing PR branch when it is safe.'
        )
    }

    stages {
        stage('🔧 Setup') {
            steps {
                echo '📦 Checking GitHub Copilot CLI installation...'
                sh '''
                    mkdir -p docs reports

                    if ! command -v copilot >/dev/null 2>&1; then
                        echo "Installing GitHub Copilot CLI..."
                        curl -fsSL https://gh.io/copilot-install | PREFIX="$HOME/.local" bash
                    fi

                    copilot --version
                    echo "✅ GitHub Copilot CLI is ready"
                '''
            }
        }

        stage('🔎 Prepare PR Context') {
            steps {
                echo '🔍 Detecting PR context, author permission, and documentation candidates...'
                sh '''
                    set -eu

                    mkdir -p docs reports

                    cat > reports/docs-generator.md <<EOF
# Documentation Generator Report

Generated: $(date)
Build: #${BUILD_NUMBER}

EOF

                    if git log -1 --pretty=%B | grep -Fq '[skip docs-generator]'; then
                        cat > reports/pr-context.env <<'EOF'
SKIP_DOCS_GENERATOR=true
PR_NUMBER=
PR_URL=
HEAD_BRANCH=
BASE_BRANCH=
AUTHOR_LOGIN=
AUTHOR_PERMISSION=
IS_CROSS_REPOSITORY=false
CAN_WRITE=false
EOF
                        echo "## Result" >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        echo "Skipped because latest commit contains [skip docs-generator]." >> reports/docs-generator.md
                        exit 0
                    fi

                    EFFECTIVE_PR="${PR_NUMBER:-${CHANGE_ID:-}}"
                    if [ -z "$EFFECTIVE_PR" ]; then
                        cat > reports/pr-context.env <<'EOF'
SKIP_DOCS_GENERATOR=true
PR_NUMBER=
PR_URL=
HEAD_BRANCH=
BASE_BRANCH=
AUTHOR_LOGIN=
AUTHOR_PERMISSION=
IS_CROSS_REPOSITORY=false
CAN_WRITE=false
EOF
                        echo "## Result" >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        echo "Skipped because no PR was detected. This job only writes documentation for existing PRs." >> reports/docs-generator.md
                        exit 0
                    fi

                                        node - <<'NODE' > reports/repo.env
const remote = require('child_process').execSync('git config --get remote.origin.url', { encoding: 'utf8' }).trim();
let cleaned = remote;
if (cleaned.startsWith('git@github.com:')) {
    cleaned = cleaned.slice('git@github.com:'.length);
}
if (cleaned.startsWith('https://github.com/')) {
    cleaned = cleaned.slice('https://github.com/'.length);
}
if (cleaned.endsWith('.git')) {
    cleaned = cleaned.slice(0, -4);
}
const parts = cleaned.split('/');
if (parts.length < 2) {
    throw new Error(`Cannot determine GitHub repository from remote URL: ${remote}`);
}
console.log(`REPO_OWNER=${parts[0]}`);
console.log(`REPO_NAME=${parts[1]}`);
NODE
                                        . reports/repo.env

                                        curl -fsSL \
                                                -H "Authorization: Bearer ${GH_TOKEN}" \
                                                -H "Accept: application/vnd.github+json" \
                                                "https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/pulls/${EFFECTIVE_PR}" > reports/pr.json

                    node - <<'NODE' > reports/permission-request.env
const fs = require('fs');
const pr = JSON.parse(fs.readFileSync('reports/pr.json', 'utf8'));
console.log(`AUTHOR_LOGIN=${pr.user.login}`);
NODE
                    . reports/permission-request.env

                                        curl -fsSL \
                                                -H "Authorization: Bearer ${GH_TOKEN}" \
                                                -H "Accept: application/vnd.github+json" \
                                                "https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/collaborators/${AUTHOR_LOGIN}/permission" > reports/author-permission.json || cat > reports/author-permission.json <<'EOF'
{"permission":"none","role_name":"none"}
EOF

                    node - <<'NODE' > reports/pr-context.env
const fs = require('fs');
const pr = JSON.parse(fs.readFileSync('reports/pr.json', 'utf8'));
const repoEnv = fs.readFileSync('reports/repo.env', 'utf8').trim().split(String.fromCharCode(10)).reduce((acc, line) => {
    const index = line.indexOf('=');
    acc[line.slice(0, index)] = line.slice(index + 1);
    return acc;
}, {});
const permission = JSON.parse(fs.readFileSync('reports/author-permission.json', 'utf8'));
const authorPermission = permission.permission || permission.role_name || 'none';
const allowedPermissions = new Set(['admin', 'maintain', 'write']);
const sameRepo = pr.head.repo.full_name === `${repoEnv.REPO_OWNER}/${repoEnv.REPO_NAME}`;
const canWrite = sameRepo && allowedPermissions.has(authorPermission);
console.log('SKIP_DOCS_GENERATOR=false');
console.log(`REPO_OWNER=${repoEnv.REPO_OWNER}`);
console.log(`REPO_NAME=${repoEnv.REPO_NAME}`);
console.log(`PR_NUMBER=${pr.number}`);
console.log(`PR_URL=${pr.html_url}`);
console.log(`HEAD_BRANCH=${pr.head.ref}`);
console.log(`BASE_BRANCH=${pr.base.ref}`);
console.log(`AUTHOR_LOGIN=${pr.user.login}`);
console.log(`AUTHOR_PERMISSION=${authorPermission}`);
console.log(`IS_CROSS_REPOSITORY=${!sameRepo}`);
console.log(`CAN_WRITE=${canWrite}`);
NODE

                    . reports/pr-context.env

                    echo "## PR Context" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md
                    echo "- PR: ${PR_URL}" >> reports/docs-generator.md
                    echo "- Author: ${AUTHOR_LOGIN}" >> reports/docs-generator.md
                    echo "- Author repository permission: ${AUTHOR_PERMISSION}" >> reports/docs-generator.md
                    echo "- Source branch: ${HEAD_BRANCH}" >> reports/docs-generator.md
                    echo "- Target branch: ${BASE_BRANCH}" >> reports/docs-generator.md
                    echo "- Cross-repository PR: ${IS_CROSS_REPOSITORY}" >> reports/docs-generator.md
                    echo "- Write-back enabled: ${WRITE_BACK_TO_PR}" >> reports/docs-generator.md
                    echo "- Allowed to generate and push docs: ${CAN_WRITE}" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md

                    if [ "$CAN_WRITE" != "true" ]; then
                        echo "## Result" >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        echo "Skipped. Documentation generation only runs for same-repository PRs opened by users with admin, maintain, or write permission." >> reports/docs-generator.md
                        exit 0
                    fi

                    git remote set-url origin "https://x-access-token:${GH_TOKEN}@github.com/${REPO_OWNER}/${REPO_NAME}.git"
                    git fetch origin "$HEAD_BRANCH"
                    git checkout -B "$HEAD_BRANCH" "origin/$HEAD_BRANCH"

                                        curl -fsSL \
                                                -H "Authorization: Bearer ${GH_TOKEN}" \
                                                -H "Accept: application/vnd.github+json" \
                                                "https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/pulls/${PR_NUMBER}/files?per_page=100" > reports/pr-files.json
                                        node - <<'NODE' > reports/pr-changed-files.txt
const fs = require('fs');
const files = JSON.parse(fs.readFileSync('reports/pr-files.json', 'utf8'));
for (const file of files) {
    console.log(file.filename);
}
NODE

                    grep -E '^(src|jenkins-copilot-chat-plugin/src|pipelines|scripts)/.*[.](ts|js|java|groovy|jenkinsfile)$|^(README|README[.]en|docs)/.*[.]md$' \
                        reports/pr-changed-files.txt > reports/doc-candidates.raw || true
                    while IFS= read -r file; do
                        [ -n "$file" ] && [ -f "$file" ] && printf '%s\n' "$file"
                    done < reports/doc-candidates.raw > reports/doc-candidates.txt

                    grep -E '^(src|jenkins-copilot-chat-plugin/src)/.*[.](ts|js|java)$' reports/doc-candidates.txt \
                        | grep -Ev '(^|[.])(test|spec)[.](ts|js|java)$' > reports/comment-candidates.txt || true

                    echo "## Changed Files Considered" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md
                    if [ -s reports/doc-candidates.txt ]; then
                        sed 's/^/- /' reports/doc-candidates.txt >> reports/docs-generator.md
                    else
                        echo "No documentation-relevant changed files were found." >> reports/docs-generator.md
                    fi
                    echo "" >> reports/docs-generator.md

                    echo "## Source Files Eligible For Documentation Comments" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md
                    if [ -s reports/comment-candidates.txt ]; then
                        sed 's/^/- /' reports/comment-candidates.txt >> reports/docs-generator.md
                    else
                        echo "No changed source files were eligible for documentation comments." >> reports/docs-generator.md
                    fi
                    echo "" >> reports/docs-generator.md
                '''
            }
        }

        stage('📚 Generate README Updates') {
            when {
                expression { params.DOC_TYPE == 'README' || params.DOC_TYPE == 'ALL' }
            }
            steps {
                echo '🤖 Generating PR-aware README documentation with Copilot...'
                sh '''
                    set -eu
                    . reports/pr-context.env
                    [ "$CAN_WRITE" = "true" ] || exit 0

                    if ! grep -Eq '^(README|README[.]en|docs/|src/|jenkins-copilot-chat-plugin/src/|pipelines/|scripts/)' reports/doc-candidates.txt; then
                        echo "## README Updates" >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        echo "Skipped because no changed files appear to affect README-level documentation." >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        exit 0
                    fi

                    cat > reports/readme-prompt.md <<'EOF'
Review the changed files in this pull request and decide whether README-style documentation should be updated.
If useful, create or update Markdown files under docs/ only. Prefer docs/PR_DOCUMENTATION.md for PR-specific notes.
Do not modify source code, package files, Jenkinsfiles, existing README files, or files outside docs/.
Do not include timestamps. Keep the result concise and reviewable.
EOF

                    {
                        echo ""
                        echo "Changed files:"
                        cat reports/doc-candidates.txt
                        echo ""
                        echo "Relevant file excerpts:"
                        while IFS= read -r file; do
                            echo ""
                            echo "--- $file ---"
                            head -160 "$file"
                        done < reports/doc-candidates.txt
                    } >> reports/readme-prompt.md

                    set +x
                    copilot --autopilot --yolo --max-autopilot-continues 3 --prompt "$(cat reports/readme-prompt.md)" > reports/readme-copilot-output.txt 2>&1
                    copilot_status=$?
                    set -x

                    echo "## README Updates" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md
                    head -120 reports/readme-copilot-output.txt >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md

                    if [ "$copilot_status" -ne 0 ]; then
                        exit "$copilot_status"
                    fi
                '''
            }
        }

        stage('📖 Generate API Docs') {
            when {
                expression { params.DOC_TYPE == 'API' || params.DOC_TYPE == 'ALL' }
            }
            steps {
                echo '🤖 Generating PR-aware API documentation with Copilot...'
                sh '''
                    set -eu
                    . reports/pr-context.env
                    [ "$CAN_WRITE" = "true" ] || exit 0

                    cp reports/comment-candidates.txt reports/api-candidates.txt
                    if [ ! -s reports/api-candidates.txt ]; then
                        echo "## API Documentation" >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        echo "Skipped because no changed source files require API documentation." >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        exit 0
                    fi

                    cat > reports/api-prompt.md <<'EOF'
Review the changed source files from this pull request and update documentation only when it is useful.
Allowed changes:
- Create or update Markdown files under docs/.
- Add missing documentation comments in the changed source files listed below. For TypeScript/JavaScript use JSDoc. For Java use JavaDoc.
- If a changed exported function, class, type, or public Java member lacks a documentation comment, add one.

Do not modify executable code, tests, package files, Jenkinsfiles, README files, or files outside docs/ and the listed source files.
Do not include timestamps. Keep documentation concise and useful for reviewers.
EOF

                    {
                        echo ""
                        echo "Changed source files:"
                        cat reports/api-candidates.txt
                        echo ""
                        echo "Relevant file excerpts:"
                        while IFS= read -r file; do
                            echo ""
                            echo "--- $file ---"
                            head -220 "$file"
                        done < reports/api-candidates.txt
                    } >> reports/api-prompt.md

                    set +x
                    copilot --autopilot --yolo --max-autopilot-continues 3 --prompt "$(cat reports/api-prompt.md)" > reports/api-copilot-output.txt 2>&1
                    copilot_status=$?
                    set -x

                    echo "## API Documentation" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md
                    head -140 reports/api-copilot-output.txt >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md

                    if [ "$copilot_status" -ne 0 ]; then
                        exit "$copilot_status"
                    fi
                '''
            }
        }

        stage('⬆️ Commit Documentation to PR') {
            when {
                expression { params.WRITE_BACK_TO_PR }
            }
            steps {
                echo '📝 Committing generated documentation back to the PR branch when safe...'
                sh '''
                    set -eu
                    . reports/pr-context.env

                    if [ "$CAN_WRITE" != "true" ]; then
                        echo "Skipping write-back because PR author is not allowed or PR is cross-repository."
                        exit 0
                    fi

                    git diff --name-only > reports/modified-files.txt
                    if [ -s reports/modified-files.txt ]; then
                        while IFS= read -r file; do
                            case "$file" in
                                docs/*)
                                    ;;
                                *)
                                    if ! grep -Fxq "$file" reports/comment-candidates.txt; then
                                        echo "Copilot modified a file outside docs/ and outside the eligible source comment list. Refusing to commit: $file"
                                        exit 1
                                    fi
                                    ;;
                            esac
                        done < reports/modified-files.txt
                    fi

                    if [ ! -s reports/modified-files.txt ]; then
                        echo "No documentation changes generated."
                        echo "## Write-back" >> reports/docs-generator.md
                        echo "" >> reports/docs-generator.md
                        echo "No documentation or source-comment changes were generated." >> reports/docs-generator.md
                        exit 0
                    fi

                    git diff > reports/generated-docs.patch

                    git config user.name "jenkins-copilot"
                    git config user.email "jenkins-copilot@users.noreply.github.com"
                    git remote set-url origin "https://x-access-token:${GH_TOKEN}@github.com/${REPO_OWNER}/${REPO_NAME}.git"

                    git fetch origin "$HEAD_BRANCH"
                    git checkout -B "$HEAD_BRANCH" "origin/$HEAD_BRANCH"
                    git apply reports/generated-docs.patch

                    git add docs
                    while IFS= read -r file; do
                        [ -f "$file" ] && git add "$file"
                    done < reports/comment-candidates.txt

                    git commit -m "docs: update Copilot-generated documentation [skip docs-generator]"
                    git push origin "HEAD:$HEAD_BRANCH"

                    echo "## Write-back" >> reports/docs-generator.md
                    echo "" >> reports/docs-generator.md
                    echo "Committed generated documentation/comment updates back to PR #${PR_NUMBER}." >> reports/docs-generator.md
                '''
            }
        }
    }

    post {
        always {
            echo '📁 Archiving documentation and report...'
            script {
                if (fileExists('reports/docs-generator.md')) {
                    def report = load 'scripts/md-to-html-report.groovy'
                    report.convert('reports/docs-generator.md', 'reports/docs-generator.html', 'Documentation Generator Report')
                }
            }
            archiveArtifacts artifacts: 'docs/*.md, reports/*.md, reports/*.txt, reports/*.html, reports/*.css, reports/*.json', allowEmptyArchive: true
            publishHTML(target: [
                reportDir: 'reports',
                reportFiles: 'docs-generator.html',
                reportName: 'Copilot Documentation Generator Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
        success {
            echo '✅ Documentation generation completed successfully!'
        }
        failure {
            echo '❌ Documentation generation failed!'
        }
    }
}
