pipeline {
    agent any

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        GH_TOKEN = credentials('gh-token')
        COPILOT_GITHUB_TOKEN = credentials('gh-token')
        COPILOT_MODEL = 'claude-sonnet-4.6'
        PATH = "${env.HOME}/.local/bin:/usr/local/bin:${env.PATH}"
    }

    stages {
        stage('🔎 PR Context') {
            steps {
                script {
                    if (!env.CHANGE_ID || !env.CHANGE_TARGET) {
                        error 'This pipeline must run from a Pull Request build in a Multibranch Pipeline.'
                    }

                    echo "Reviewing PR #${env.CHANGE_ID}"
                    echo "Source branch: ${env.CHANGE_BRANCH}"
                    echo "Target branch: ${env.CHANGE_TARGET}"
                }
            }
        }

        stage('🔧 Setup') {
            steps {
                echo 'Checking GitHub Copilot CLI installation...'
                sh 'sh scripts/common/setup-copilot.sh reports'
            }
        }

        stage('📥 Fetch Base Branch') {
            steps {
                echo 'Fetching Pull Request target branch...'
                sh '''
                    git fetch --no-tags origin "+refs/heads/${CHANGE_TARGET}:refs/remotes/origin/${CHANGE_TARGET}"
                '''
            }
        }

        stage('📂 Files') {
            steps {
                echo 'Collecting source files for review...'
                sh 'node scripts/code-review/prepare-files.mjs'
            }
        }

        stage('📝 Review') {
            steps {
                echo 'Running Copilot code review...'
                sh 'node scripts/code-review/review.mjs'
            }
        }

        stage('📊 Summary') {
            steps {
                echo 'Generating review summary...'
                sh 'node scripts/code-review/summary.mjs'
            }
        }

        stage('💬 PR Comment') {
            steps {
                echo 'Publishing code review comment on Pull Request...'
                sh 'node scripts/code-review/comment-pr.mjs'
            }
        }
    }

    post {
        always {
            echo 'Archiving review report...'
            script {
                if (fileExists('reports/code-review.md')) {
                    def report = load 'scripts/common/md-to-html-report.groovy'
                    report.convert('reports/code-review.md', 'reports/code-review.html', 'Code Review Report')
                }
            }
            archiveArtifacts artifacts: 'reports/*.md, reports/*.txt, reports/*.html, reports/*.css, reports/*.json', allowEmptyArchive: true
            publishHTML(target: [
                reportDir: 'reports',
                reportFiles: 'code-review.html',
                reportName: 'Copilot Code Review Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
        success {
            echo 'Code review pipeline completed successfully!'
        }
        failure {
            echo 'Code review pipeline failed!'
        }
    }
}
