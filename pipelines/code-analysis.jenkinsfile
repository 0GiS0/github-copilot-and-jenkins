pipeline {
    agent any
    
    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }
    
    environment {
        GH_TOKEN = credentials('gh-token')
        COPILOT_GITHUB_TOKEN = credentials('gh-token')
        PATH = "${env.HOME}/.local/bin:/usr/local/bin:${env.PATH}"
    }
    
    stages {
        stage('🔧 Setup') {
            steps {
                echo '📦 Checking GitHub Copilot CLI installation...'
                sh '''
                    if ! command -v copilot >/dev/null 2>&1; then
                        echo "Installing GitHub Copilot CLI..."
                        curl -fsSL https://gh.io/copilot-install | PREFIX="$HOME/.local" bash
                    fi

                    copilot --version
                    echo "✅ GitHub Copilot CLI is ready"
                '''
            }
        }
        
        stage('📊 Project Overview') {
            steps {
                echo '🔍 Analyzing project structure...'
                sh '''
                    mkdir -p analysis
                    
                    echo "# Project Analysis Report" > analysis/report.md
                    echo "" >> analysis/report.md
                    echo "Generated: $(date)" >> analysis/report.md
                    echo "Build: #${BUILD_NUMBER}" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    echo "## Project Statistics" >> analysis/report.md
                    echo "" >> analysis/report.md
                    echo "| Metric | Value |" >> analysis/report.md
                    echo "|--------|-------|" >> analysis/report.md
                    echo "| TypeScript files | $(find src -name '*.ts' | wc -l) |" >> analysis/report.md
                    echo "| Test files | $(find src -name '*.test.ts' | wc -l) |" >> analysis/report.md
                    echo "| Total lines | $(find src -name '*.ts' -exec cat {} + | wc -l) |" >> analysis/report.md
                    echo "" >> analysis/report.md
                '''
            }
        }
        
        stage('🔍 Code Complexity Analysis') {
            steps {
                echo '🤖 Analyzing code complexity with Copilot...'
                sh '''
                    echo "## Complexity Analysis" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    for file in $(find src -name "*.ts" -type f | grep -v test | head -5); do
                        echo "### $(basename $file)" >> analysis/report.md
                        echo "" >> analysis/report.md
                        
                        # Count functions
                        FUNC_COUNT=$(grep -c "function" "$file" 2>/dev/null || echo "0")
                        echo "- Functions: $FUNC_COUNT" >> analysis/report.md
                        
                        # Lines of code
                        LOC=$(wc -l < "$file")
                        echo "- Lines: $LOC" >> analysis/report.md
                        
                        # Ask Copilot CLI agent for complexity suggestions
                        echo "" >> analysis/report.md
                        echo "**Copilot Analysis:**" >> analysis/report.md
                        echo "" >> analysis/report.md

                        cat > analysis/copilot-prompt.txt <<EOF
Analyze this TypeScript file for complexity, maintainability, and focused improvement opportunities.
Return a concise Markdown section. Do not modify files.

File: $file

$(head -80 "$file")
EOF

                        set +x
                        copilot --autopilot --yolo --max-autopilot-continues 3 --prompt "$(cat analysis/copilot-prompt.txt)" > analysis/copilot-output.txt 2>&1
                        copilot_status=$?
                        set -x
                        head -80 analysis/copilot-output.txt >> analysis/report.md
                        if [ "$copilot_status" -ne 0 ]; then
                            exit "$copilot_status"
                        fi
                        echo "" >> analysis/report.md
                    done
                '''
            }
        }
        
        stage('🛡️ Security Suggestions') {
            steps {
                echo '🔒 Getting security suggestions from Copilot...'
                sh '''
                    echo "## Security Analysis" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    # Check for common patterns
                    echo "### Potential Security Patterns Found" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    # Look for potential issues
                    if grep -r "eval(" src/ 2>/dev/null; then
                        echo "⚠️ Found eval() usage - potential security risk" >> analysis/report.md
                    fi
                    
                    if grep -r "innerHTML" src/ 2>/dev/null; then
                        echo "⚠️ Found innerHTML usage - potential XSS risk" >> analysis/report.md
                    fi
                    
                    echo "" >> analysis/report.md
                    echo "**Copilot Security Recommendations:**" >> analysis/report.md
                    echo "" >> analysis/report.md

                    cat > analysis/copilot-security-prompt.txt <<'EOF'
Review this Node.js TypeScript project for security risks.
Focus on practical recommendations for code in src/, dependency usage, secrets handling, and CI safety.
Return concise Markdown bullets. Do not modify files.
EOF

                    set +x
                    copilot --autopilot --yolo --max-autopilot-continues 3 --prompt "$(cat analysis/copilot-security-prompt.txt)" > analysis/copilot-output.txt 2>&1
                    copilot_status=$?
                    set -x
                    head -80 analysis/copilot-output.txt >> analysis/report.md
                    if [ "$copilot_status" -ne 0 ]; then
                        exit "$copilot_status"
                    fi
                '''
            }
        }
        
        stage('💡 Improvement Suggestions') {
            steps {
                echo '✨ Getting improvement suggestions from Copilot...'
                sh '''
                    echo "## Improvement Suggestions" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    # Get general suggestions
                    echo "### General Recommendations" >> analysis/report.md
                    echo "" >> analysis/report.md

                    cat > analysis/copilot-improvements-prompt.txt <<'EOF'
Suggest improvements for this TypeScript utility project.
Review the repository structure, source code, and scripts. Return concise Markdown bullets grouped by impact.
Do not modify files.
EOF

                    set +x
                    copilot --autopilot --yolo --max-autopilot-continues 3 --prompt "$(cat analysis/copilot-improvements-prompt.txt)" > analysis/copilot-output.txt 2>&1
                    copilot_status=$?
                    set -x
                    head -100 analysis/copilot-output.txt >> analysis/report.md
                    if [ "$copilot_status" -ne 0 ]; then
                        exit "$copilot_status"
                    fi
                    
                    echo "" >> analysis/report.md
                    echo "### Testing Recommendations" >> analysis/report.md
                    echo "" >> analysis/report.md

                    cat > analysis/copilot-testing-prompt.txt <<'EOF'
Review testing practices for this TypeScript Jest project.
Focus on missing edge cases, useful test organization, and CI-friendly recommendations.
Return concise Markdown. Do not modify files.
EOF

                    set +x
                    copilot --autopilot --yolo --max-autopilot-continues 3 --prompt "$(cat analysis/copilot-testing-prompt.txt)" > analysis/copilot-output.txt 2>&1
                    copilot_status=$?
                    set -x
                    head -80 analysis/copilot-output.txt >> analysis/report.md
                    if [ "$copilot_status" -ne 0 ]; then
                        exit "$copilot_status"
                    fi
                '''
            }
        }
    }
    
    post {
        always {
            echo '📁 Archiving analysis report...'
            sh '''
                if [ -f analysis/report.md ]; then
                    python3 - <<'PY'
from pathlib import Path

markdown = Path('analysis/report.md').read_text(encoding='utf-8')

def escape(value: str) -> str:
    return (
        str(value)
        .replace('&', '&amp;')
        .replace('<', '&lt;')
        .replace('>', '&gt;')
        .replace('"', '&quot;')
        .replace("'", '&#x27;')
    )

def render_inline(text: str) -> str:
    result = []
    index = 0
    while index < len(text):
        if text[index] == '`':
            end = text.find('`', index + 1)
            if end != -1:
                result.append(f'<code>{escape(text[index + 1:end])}</code>')
                index = end + 1
                continue
            result.append('`')
            index += 1
            continue
        if text.startswith('**', index):
            end = text.find('**', index + 2)
            if end != -1:
                result.append(f'<strong>{render_inline(text[index + 2:end])}</strong>')
                index = end + 2
                continue
            result.append('**')
            index += 2
            continue
        next_code = text.find('`', index)
        next_bold = text.find('**', index)
        candidates = [position for position in (next_code, next_bold) if position != -1]
        next_marker = min(candidates) if candidates else len(text)
        if next_marker == index:
            result.append(escape(text[index]))
            index += 1
            continue
        result.append(escape(text[index:next_marker]))
        index = next_marker
    return ''.join(result)

def render_markdown(source: str) -> str:
    lines = source.splitlines()
    output = []
    in_ul = False
    in_table = False
    table_has_header = False
    in_section = False

    def close_blocks():
        nonlocal in_ul, in_table, table_has_header
        if in_ul:
            output.append('</ul>')
            in_ul = False
        if in_table:
            output.append('</tbody></table></div>')
            in_table = False
            table_has_header = False

    def close_section():
        nonlocal in_section
        if in_section:
            close_blocks()
            output.append('</div></details>')
            in_section = False

    for line in lines:
        stripped = line.strip()
        if not stripped:
            close_blocks()
            continue
        if stripped == '---':
            close_blocks()
            output.append('<hr>')
            continue
        if stripped.startswith('|') and stripped.endswith('|'):
            cells = [render_inline(cell.strip()) for cell in stripped.strip('|').split('|')]
            if all(set(cell.replace('-', '').replace(':', '').strip()) == set() for cell in cells):
                continue
            if not in_table:
                close_blocks()
                output.append('<div class="table-wrap"><table><tbody>')
                in_table = True
                table_has_header = False
            tag = 'th' if not table_has_header else 'td'
            table_has_header = True
            output.append('<tr>' + ''.join(f'<{tag}>{cell}</{tag}>' for cell in cells) + '</tr>')
            continue
        if stripped.startswith('- '):
            if in_table:
                output.append('</tbody></table></div>')
                in_table = False
                table_has_header = False
            if not in_ul:
                output.append('<ul>')
                in_ul = True
            output.append(f'<li>{render_inline(stripped[2:])}</li>')
            continue
        close_blocks()
        if stripped.startswith('#### '):
            output.append(f'<h4>{render_inline(stripped[5:])}</h4>')
        elif stripped.startswith('### '):
            output.append(f'<h3>{render_inline(stripped[4:])}</h3>')
        elif stripped.startswith('## '):
            close_section()
            output.append(f'<details class="report-section"><summary>{render_inline(stripped[3:])}</summary><div class="section-body">')
            in_section = True
        elif stripped.startswith('# '):
            output.append(f'<h1>{render_inline(stripped[2:])}</h1>')
        else:
            output.append(f'<p>{render_inline(stripped)}</p>')
    close_blocks()
    close_section()
    return chr(10).join(output)

body = render_markdown(markdown)
css = """
:root {
    color-scheme: light;
    --bg: #f6f8fa;
    --panel: #ffffff;
    --text: #1f2328;
    --muted: #656d76;
    --border: #d0d7de;
    --accent: #0969da;
    --accent-soft: #ddf4ff;
    --success: #1a7f37;
    --warning: #9a6700;
    --danger: #cf222e;
}
* { box-sizing: border-box; }
body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font: 15px/1.6 -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
}
.report-shell {
    max-width: 1120px;
    margin: 0 auto;
    padding: 32px 24px 48px;
}
.back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
}
.back-link:hover { text-decoration: underline; }
.report-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 16px 42px rgba(31, 35, 40, .08);
    overflow: hidden;
}
.report-header {
    padding: 28px 32px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, #ffffff 0%, #f6f8fa 100%);
}
.report-header h1 {
    margin: 0 0 10px;
    font-size: 32px;
    line-height: 1.2;
    letter-spacing: 0;
}
.report-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--muted);
}
.meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--panel);
    padding: 4px 10px;
    font-size: 13px;
}
.report-content { padding: 24px 32px 34px; }
h1:first-child, p:nth-child(2), p:nth-child(3) { display: none; }
.report-section {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--panel);
    margin: 16px 0;
    overflow: hidden;
}
.report-section summary {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    padding: 15px 18px;
    background: #f6f8fa;
    color: var(--text);
    font-size: 19px;
    font-weight: 700;
    user-select: none;
}
.report-section summary::before {
    content: '›';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: var(--accent);
    font-size: 22px;
    line-height: 1;
    transform: rotate(0deg);
    transition: transform .12s ease;
}
.report-section[open] summary::before { transform: rotate(90deg); }
.report-section summary::-webkit-details-marker { display: none; }
.section-body { padding: 6px 18px 18px; }
h2 {
    margin: 30px 0 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    font-size: 22px;
}
h3 {
    margin: 24px 0 10px;
    color: var(--accent);
    font-size: 18px;
}
h4 { margin: 18px 0 8px; font-size: 16px; }
p { margin: 10px 0; }
ul { margin: 10px 0 16px 22px; padding: 0; }
li { margin: 6px 0; }
strong { font-weight: 700; }
code {
    border: 1px solid var(--border);
    border-radius: 5px;
    background: #f6f8fa;
    padding: 1px 5px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: .92em;
}
hr { border: 0; border-top: 1px solid var(--border); margin: 22px 0; }
.table-wrap { overflow-x: auto; margin: 14px 0 20px; }
table {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
}
th, td {
    border-bottom: 1px solid var(--border);
    padding: 10px 12px;
    text-align: left;
    vertical-align: top;
}
th { background: #f6f8fa; font-weight: 700; }
tr:last-child td { border-bottom: 0; }
@media (max-width: 720px) {
    .report-shell { padding: 16px; }
    .report-header, .report-content { padding: 22px 18px; }
    .report-header h1 { font-size: 26px; }
    .report-section summary { font-size: 17px; padding: 13px 14px; }
    .section-body { padding: 4px 14px 14px; }
}
"""
html = f"""<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Code Analysis Report</title>
    <link rel="stylesheet" href="report.css">
</head>
<body>
    <main class="report-shell">
        <a class="back-link" href="../../">&larr; Back to Jenkins build</a>
        <article class="report-card">
            <header class="report-header">
                <h1>Project Analysis Report</h1>
                <div class="report-meta">
                    <span class="meta-pill">Generated by GitHub Copilot CLI</span>
                    <span class="meta-pill">Jenkins build report</span>
                </div>
            </header>
            <section class="report-content">
                {body}
            </section>
        </article>
    </main>
</body>
</html>
"""
Path('analysis/report.css').write_text(css, encoding='utf-8')
Path('analysis/report.html').write_text(html, encoding='utf-8')
PY
                fi
            '''
            archiveArtifacts artifacts: 'analysis/*.md, analysis/*.html, analysis/*.css', allowEmptyArchive: true
            publishHTML(target: [
                reportDir: 'analysis',
                reportFiles: 'report.html',
                reportName: 'Copilot Code Analysis Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
        success {
            echo '✅ Code analysis completed successfully!'
        }
        failure {
            echo '❌ Code analysis failed!'
        }
    }
}
