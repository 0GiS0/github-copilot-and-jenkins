pipeline {
    agent any
    
    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }
    
    environment {
        GH_TOKEN = credentials('gh-token')
        COPILOT_GITHUB_TOKEN = credentials('gh-token')
        PATH = "${env.HOME}/.local/bin:/usr/local/bin:${env.PATH}"
    }
    
    stages {
        stage('🔧 Setup') {
            steps {
                echo '📦 Checking GitHub Copilot CLI installation...'
                sh '''
                    if ! command -v copilot >/dev/null 2>&1; then
                        echo "Installing GitHub Copilot CLI..."
                        curl -fsSL https://gh.io/copilot-install | PREFIX="$HOME/.local" bash
                    fi

                    copilot --version
                    echo "✅ GitHub Copilot CLI is ready"
                '''
            }
        }
        
        stage('📊 Project Overview') {
            steps {
                echo '🔍 Analyzing project structure...'
                sh '''
                    mkdir -p analysis
                    
                    echo "# Project Analysis Report" > analysis/report.md
                    echo "" >> analysis/report.md
                    echo "Generated: $(date)" >> analysis/report.md
                    echo "Build: #${BUILD_NUMBER}" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    echo "## Project Statistics" >> analysis/report.md
                    echo "" >> analysis/report.md
                    echo "| Metric | Value |" >> analysis/report.md
                    echo "|--------|-------|" >> analysis/report.md
                    echo "| TypeScript files | $(find src -name '*.ts' | wc -l) |" >> analysis/report.md
                    echo "| Test files | $(find src -name '*.test.ts' | wc -l) |" >> analysis/report.md
                    echo "| Total lines | $(find src -name '*.ts' -exec cat {} + | wc -l) |" >> analysis/report.md
                    echo "" >> analysis/report.md
                '''
            }
        }
        
        stage('🔍 Code Complexity Analysis') {
            steps {
                echo '🤖 Analyzing code complexity with Copilot...'
                sh '''
                    echo "## Complexity Analysis" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    for file in $(find src -name "*.ts" -type f | grep -v test | head -5); do
                        echo "### $(basename $file)" >> analysis/report.md
                        echo "" >> analysis/report.md
                        
                        # Count functions
                        FUNC_COUNT=$(grep -c "function" "$file" 2>/dev/null || echo "0")
                        echo "- Functions: $FUNC_COUNT" >> analysis/report.md
                        
                        # Lines of code
                        LOC=$(wc -l < "$file")
                        echo "- Lines: $LOC" >> analysis/report.md
                        
                        # Ask Copilot CLI agent for complexity suggestions
                        echo "" >> analysis/report.md
                        echo "**Copilot Analysis:**" >> analysis/report.md
                        echo "" >> analysis/report.md

                        cat > analysis/copilot-prompt.txt <<EOF
Use the Explore agent to analyze this TypeScript file for complexity, maintainability, and focused improvement opportunities.
Return a concise Markdown section. Do not modify files.

File: $file

$(head -80 "$file")
EOF

                        copilot --autopilot --yolo --max-autopilot-continues 3 --agent=explore --prompt "$(cat analysis/copilot-prompt.txt)" 2>&1 | head -80 >> analysis/report.md || echo "Copilot CLI analysis could not be completed" >> analysis/report.md
                        echo "" >> analysis/report.md
                    done
                '''
            }
        }
        
        stage('🛡️ Security Suggestions') {
            steps {
                echo '🔒 Getting security suggestions from Copilot...'
                sh '''
                    echo "## Security Analysis" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    # Check for common patterns
                    echo "### Potential Security Patterns Found" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    # Look for potential issues
                    if grep -r "eval(" src/ 2>/dev/null; then
                        echo "⚠️ Found eval() usage - potential security risk" >> analysis/report.md
                    fi
                    
                    if grep -r "innerHTML" src/ 2>/dev/null; then
                        echo "⚠️ Found innerHTML usage - potential XSS risk" >> analysis/report.md
                    fi
                    
                    echo "" >> analysis/report.md
                    echo "**Copilot Security Recommendations:**" >> analysis/report.md
                    echo "" >> analysis/report.md

                    cat > analysis/copilot-security-prompt.txt <<'EOF'
Use the Explore agent to review this Node.js TypeScript project for security risks.
Focus on practical recommendations for code in src/, dependency usage, secrets handling, and CI safety.
Return concise Markdown bullets. Do not modify files.
EOF

                    copilot --autopilot --yolo --max-autopilot-continues 3 --agent=explore --prompt "$(cat analysis/copilot-security-prompt.txt)" 2>&1 | head -80 >> analysis/report.md || echo "Copilot CLI security recommendations could not be completed" >> analysis/report.md
                '''
            }
        }
        
        stage('💡 Improvement Suggestions') {
            steps {
                echo '✨ Getting improvement suggestions from Copilot...'
                sh '''
                    echo "## Improvement Suggestions" >> analysis/report.md
                    echo "" >> analysis/report.md
                    
                    # Get general suggestions
                    echo "### General Recommendations" >> analysis/report.md
                    echo "" >> analysis/report.md

                    cat > analysis/copilot-improvements-prompt.txt <<'EOF'
Use the Explore agent to suggest improvements for this TypeScript utility project.
Review the repository structure, source code, and scripts. Return concise Markdown bullets grouped by impact.
Do not modify files.
EOF

                    copilot --autopilot --yolo --max-autopilot-continues 3 --agent=explore --prompt "$(cat analysis/copilot-improvements-prompt.txt)" 2>&1 | head -100 >> analysis/report.md || echo "Copilot CLI improvement suggestions could not be completed" >> analysis/report.md
                    
                    echo "" >> analysis/report.md
                    echo "### Testing Recommendations" >> analysis/report.md
                    echo "" >> analysis/report.md

                    cat > analysis/copilot-testing-prompt.txt <<'EOF'
Use the Explore agent to review testing practices for this TypeScript Jest project.
Focus on missing edge cases, useful test organization, and CI-friendly recommendations.
Return concise Markdown. Do not modify files.
EOF

                    copilot --autopilot --yolo --max-autopilot-continues 3 --agent=explore --prompt "$(cat analysis/copilot-testing-prompt.txt)" 2>&1 | head -80 >> analysis/report.md || echo "Copilot CLI testing suggestions could not be completed" >> analysis/report.md
                '''
            }
        }
    }
    
    post {
        always {
            echo '📁 Archiving analysis report...'
            archiveArtifacts artifacts: 'analysis/*.md', allowEmptyArchive: true
        }
        success {
            echo '✅ Code analysis completed successfully!'
        }
        failure {
            echo '❌ Code analysis failed!'
        }
    }
}
