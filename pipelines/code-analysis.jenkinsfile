pipeline {
    agent any

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        GH_TOKEN = credentials('gh-token')
        COPILOT_GITHUB_TOKEN = credentials('gh-token')
        COPILOT_MODEL = 'claude-sonnet-4.6'
        PATH = "${env.HOME}/.local/bin:/usr/local/bin:${env.PATH}"
    }

    stages {
        stage('🔧 Setup') {
            steps {
                echo 'Checking GitHub Copilot CLI installation...'
                sh 'sh scripts/common/setup-copilot.sh analysis'
            }
        }

        stage('📊 Overview') {
            steps {
                echo 'Analyzing project structure...'
                sh 'node scripts/code-analysis/project-overview.mjs'
            }
        }

        stage('🧠 Complexity') {
            steps {
                echo 'Analyzing code complexity with Copilot...'
                sh 'node scripts/code-analysis/complexity.mjs'
            }
        }

        stage('🛡️ Security') {
            steps {
                echo 'Getting security suggestions from Copilot...'
                sh 'node scripts/code-analysis/security.mjs'
            }
        }

        stage('💡 Improvements') {
            steps {
                echo 'Getting improvement suggestions from Copilot...'
                sh 'node scripts/code-analysis/improvements.mjs'
            }
        }
    }

    post {
        always {
            echo 'Archiving analysis report...'
            script {
                if (fileExists('analysis/report.md')) {
                    def report = load 'scripts/common/md-to-html-report.groovy'
                    report.convert('analysis/report.md', 'analysis/report.html', 'Project Analysis Report')
                }
            }
            archiveArtifacts artifacts: 'analysis/*.md, analysis/*.txt, analysis/*.html, analysis/*.css', allowEmptyArchive: true
            publishHTML(target: [
                reportDir: 'analysis',
                reportFiles: 'report.html',
                reportName: 'Copilot Code Analysis Report',
                keepAll: true,
                alwaysLinkToLastBuild: true,
                allowMissing: true
            ])
        }
        success {
            echo 'Code analysis completed successfully!'
        }
        failure {
            echo 'Code analysis failed!'
        }
    }
}
