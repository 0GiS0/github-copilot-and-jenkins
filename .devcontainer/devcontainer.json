{
  "name": "🤖 GitHub Copilot and 🔄 Jenkins Demo",
  "dockerComposeFile": "compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "forwardPorts": [
    8081
  ],
  "portsAttributes": {
    "8081": {
      "label": "🧪 Jenkins",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "GitHub.copilot",
        "vscjava.vscode-java-pack"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "npm install && chmod +x scripts/*.sh && scripts/setup-git-credential-helper.sh",
  "postStartCommand": "scripts/sync-jenkins-gh-token.sh || true",
  "remoteEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "nodeGypDependencies": true,
      "version": "lts",
      "pnpmVersion": "latest",
      "nvmVersion": "latest"
    },
    "ghcr.io/devcontainers-extra/features/maven-sdkman:2": {},
    "ghcr.io/devcontainers-extra/features/jenkinsx-cli:1": {},
    "ghcr.io/devcontainers/features/node:2": {},
    "ghcr.io/devcontainers-extra/features/groovy-sdkman:2": {}
  }
}