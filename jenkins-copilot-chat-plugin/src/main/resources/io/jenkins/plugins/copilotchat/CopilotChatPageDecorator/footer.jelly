<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core">
  <link rel="stylesheet" href="${rootURL}/plugin/copilot-chat/copilot-chat.css" />
  <div id="copilot-chat-widget" class="copilot-chat-widget" data-base-url="${rootURL}/copilot-chat">
    <button id="copilot-chat-toggle" class="copilot-chat-toggle" type="button" aria-label="Copilot Chat" aria-expanded="false">
      <img class="copilot-chat-toggle__icon" src="${rootURL}/plugin/copilot-chat/images/github-copilot-jenkins-logo.png" alt="" />
    </button>
    <section id="copilot-chat-panel" class="copilot-chat-panel" aria-label="Copilot Chat" hidden="hidden">
      <div id="copilot-chat-resize-handle" class="copilot-chat-resize-handle" aria-hidden="true" title="Drag to resize"></div>
      <header class="copilot-chat-header">
        <div class="copilot-chat-title">
          <img class="copilot-chat-title__logo" src="${rootURL}/plugin/copilot-chat/images/github-copilot-jenkins-logo.png" alt="" />
          <div class="copilot-chat-title__text">
            <strong>GitHub Copilot Chat</strong>
            <span id="copilot-chat-auth-status" class="copilot-chat-status"></span>
          </div>
        </div>
        <div class="copilot-chat-header__actions">
          <select id="copilot-chat-model-selector" class="copilot-chat-model-selector" title="Select AI model" hidden="hidden">
            <option value="">Loading...</option>
          </select>
          <button id="copilot-chat-logout-button" class="copilot-chat-icon-button" type="button" title="Sign out" aria-label="Sign out" hidden="hidden">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          </button>
          <button id="copilot-chat-fullscreen" class="copilot-chat-icon-button" type="button" title="Toggle fullscreen" aria-label="Toggle fullscreen">
            <svg id="copilot-chat-fullscreen-expand" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
            <svg id="copilot-chat-fullscreen-collapse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" hidden="hidden"><polyline points="4 14 10 14 10 20"></polyline><polyline points="20 10 14 10 14 4"></polyline><line x1="14" y1="10" x2="21" y2="3"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
          </button>
          <button id="copilot-chat-close" class="copilot-chat-icon-button" type="button" title="Close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </header>
      <div class="copilot-chat-body">
        <div id="copilot-chat-login" class="copilot-chat-login">
          <button id="copilot-chat-login-button" class="jenkins-button jenkins-button--primary" type="button">Sign in with GitHub</button>
          <div id="copilot-chat-device-info" class="copilot-chat-device-info" hidden="hidden">
            <div class="copilot-chat-device-container">
              <div class="copilot-chat-device-label">Device Code</div>
              <div class="copilot-chat-device-code-wrapper">
                <div id="copilot-chat-device-code" class="copilot-chat-device-code"></div>
                <button id="copilot-chat-copy-button" class="copilot-chat-copy-button" type="button" title="Copy code to clipboard" aria-label="Copy code">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                </button>
              </div>
            </div>
            <div class="copilot-chat-device-link-wrapper">
              <a id="copilot-chat-device-link" class="copilot-chat-device-link" target="_blank" rel="noopener noreferrer"></a>
            </div>
          </div>
        </div>
        <div id="copilot-chat-messages" class="copilot-chat-messages" aria-live="polite"></div>
      </div>
      <form id="copilot-chat-form" class="copilot-chat-form" hidden="hidden">
        <div class="copilot-chat-input">
          <textarea id="copilot-chat-prompt" rows="1" placeholder="Ask Copilot about Jenkins…"></textarea>
          <button id="copilot-chat-send" class="copilot-chat-send" type="submit" title="Send (Enter)" aria-label="Send">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
          </button>
        </div>
        <div class="copilot-chat-hint">Enter to send · Shift+Enter for new line</div>
      </form>
    </section>
  </div>
  <script src="${rootURL}/plugin/copilot-chat/copilot-chat.js"></script>
</j:jelly>